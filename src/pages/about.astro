---
import MainLayout from "../layouts/MainLayout.astro";
import aboutData from "../data/about-data.json";
---

<MainLayout title="Portfolio - À propos" namespace="about">
  <!-- Hero Section -->
  <section
    class="relative h-screen flex flex-col justify-between p-6 overflow-hidden"
  >
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-11 text-center">
        <div
          class="flex items-center justify-center ts-body"
          data-text-split="chars"
          data-text-animation="fade"
        >
          {
            aboutData.skills.map((skill, index) => (
              <Fragment>
                {skill}
                {index !== aboutData.skills.length - 1 && "/"}
              </Fragment>
            ))
          }
        </div>
      </div>
    </div>
    <div
      class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full"
    >
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-11">
          <h1
            class="ts-big text-center"
            data-text-split="lines"
            data-text-animation="slideUp"
            data-text-duration="0.8"
            data-text-trigger="load"
          >
            <Fragment set:html={aboutData.hero.title} />
          </h1>
        </div>
      </div>
    </div>
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-3 col-start-5">
        <p
          class="ts-little text-center"
          data-text-split="lines"
          data-text-animation="slideUp"
          data-text-trigger="load"
        >
          {aboutData.hero.description}
        </p>
      </div>
    </div>
  </section>

  <section
    class="transition-section absolute inset-0 w-full h-screen m-auto overflow-hidden"
    style="left: calc(100% - 7.8rem); height: 90%; width: 7.8rem;"
  >
    <nav class="absolute top-1/2 left-4 right-0 z-20 pr-4 md:pr-5 -translate-y-full pb-5">
        <ul class="flex items-center justify-start w-full">
            <li>
            <a class="ts-little transition-link block" href="/" data-barba>Back</a
            >
            </li>
        </ul>
    </nav>
    <div class="progress-back absolute top-1/2 z-20 left-5 md:left-5 right-0 h-[1px] bg-white translate-y-1/2"></div>
    <div class="relative w-full h-full">
      <div class="absolute inset-0 w-full h-full bg-[#00000033]"></div>
      <img
        id="transition-image"
        src="/images/chaillot/e242fbc5805242d87b1ede75387c2de2d13c0fbd_3908f48bc3.png"
        alt="Project"
        class="w-full h-full object-cover"
      />
    </div>
  </section>
</MainLayout>

<script>
  // Update transition image and back link from slider state
  const saved = sessionStorage.getItem("homeSliderState");
  if (saved) {
    const state = JSON.parse(saved);
    if (state.image) {
      const img = document.getElementById(
        "transition-image",
      ) as HTMLImageElement | null;
      if (img) img.src = state.image;
    }
    // Si on vient d'un projet, le lien "Back" pointe vers ce projet
    if (state.projectUrl) {
      const backLink = document.querySelector(
        ".transition-link[href='/']",
      ) as HTMLAnchorElement | null;
      if (backLink) backLink.href = state.projectUrl;
    }
  }
</script>
